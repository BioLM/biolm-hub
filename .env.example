# .env.example — template for LOCAL development configuration.
#
# Copy it to a gitignored .env and fill in what you need:
#     cp .env.example .env
# direnv auto-loads .env on `cd` (see .envrc). NEVER commit .env or real secrets.
#
# Nothing here is required to *run* the catalog: public model weights are read
# anonymously over HTTPS. These vars only configure deploys and the local R2
# client. Inside deployed Modal containers, credentials come from Modal secrets
# (`bh setup`), not from this file.

# ── Modal ──────────────────────────────────────────────────────────────────
# Modal environment (workspace sub-environment) that `bh deploy` / `bh serve`
# target. Pick any name; a dev sandbox is conventional.
MODAL_ENVIRONMENT=biolm-hub-dev

# Modal API token. Prefer `modal token new` (writes ~/.modal.toml); set these
# only for headless / CI auth. Create one at https://modal.com/settings/tokens.
#MODAL_TOKEN_ID=
#MODAL_TOKEN_SECRET=

# ── Cloudflare R2 (optional) ─────────────────────────────────────────────────
# Only needed for the LOCAL R2 client (`bh r2 …` browsing and local weight
# caching). Public weights work without any of these. Override the bucket to
# point at your own; the default is the read-only public bucket.
#BIOLM_R2_BUCKET=biolm-public
#R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
#AWS_ACCESS_KEY_ID=<your-r2-access-key-id>
#AWS_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
#AWS_REGION=auto

# ── Optional toggles ─────────────────────────────────────────────────────────
# Force credential-less mode: read/deploy public weights anonymously without
# mounting Modal R2/HF secrets. See the deploy notes in README.md.
#BIOLM_SKIP_MODAL_SECRETS=1
# Enable Modal cache volumes on deploy (off by default).
#BIOLM_CACHE_ENABLED=1
# Structured-logging verbosity (default INFO). Never logs sequences or secrets.
#LOG_LEVEL=INFO

# ── Gateway (optional; only for deploying/testing the unified gateway) ───────
#BIOLM_GATEWAY_CATALOG=1                       # also mount the browser catalog UI
#BIOLM_GATEWAY_DOMAIN=<your-gateway-domain>    # custom domain for the deployed gateway
#BIOLM_GATEWAY_CORS_ORIGINS=<comma-separated>  # allowed CORS origins
#BIOLM_GATEWAY_URL=<deployed-gateway-url>      # target for gateway deployment tests
