# .envrc — direnv config for local biolm-hub development.
#
# direnv (https://direnv.net) auto-runs this when you `cd` into the repo. It:
#   • auto-activates the uv-managed .venv, so `bh` and the dev tools are on your
#     PATH without `source .venv/bin/activate`, and
#   • loads a gitignored local .env if present (your Modal/R2 config — see
#     .env.example for the template).
#
# One-time setup:  brew install direnv → add the shell hook → run `direnv allow`.
# Re-run `direnv allow` after editing this file or in a fresh clone/worktree.
# If direnv isn't installed this file is inert — `source .venv/bin/activate`
# and `uv run bh …` still work exactly as before.

# Load local, gitignored env vars (copy .env.example to .env to get started).
dotenv_if_exists .env

# Activate the uv-managed virtualenv. `make install` (uv venv + uv sync) makes it.
if [ -d .venv ]; then
    export VIRTUAL_ENV="$PWD/.venv"
    PATH_add "$VIRTUAL_ENV/bin"
else
    log_status "No .venv found — run 'make install' to create it."
fi
